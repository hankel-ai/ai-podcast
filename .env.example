# Telegram Bot API (required if telegram.enabled: true)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Discord Webhook (required if discord.enabled: true)
DISCORD_WEBHOOK_URL=your_webhook_url_here

# Optional: For AI script mode (Claude Haiku summarization)
ANTHROPIC_API_KEY=your_api_key_here
