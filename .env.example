# Telegram Bot API (required if telegram.enabled: true)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Discord Webhook (required if discord.enabled: true)
DISCORD_WEBHOOK_URL=your_webhook_url_here

# AI script mode — pick ONE of the two options below:

# Option 1: Anthropic API key (console.anthropic.com)
ANTHROPIC_API_KEY=your_api_key_here

# Option 2: Google Vertex AI (uses Application Default Credentials)
# ANTHROPIC_VERTEX_PROJECT_ID=your_gcp_project_id
# CLOUD_ML_REGION=us-east5
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
